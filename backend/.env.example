# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your password.

# ── Gmail setup ──────────────────────────────────────────────────
# Your Gmail address (used as the "from" address)
GMAIL_USER=your-address@gmail.com

# App Password — NOT your regular Gmail password.
# Steps to get one:
#   1. Enable 2-Step Verification:  myaccount.google.com/security
#   2. Go to App Passwords:         myaccount.google.com/apppasswords
#   3. Click "Create app password"
#   4. Name it anything (e.g. "Portfolio")
#   5. Paste the 16-character password below (remove spaces)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# ── Server ───────────────────────────────────────────────────────
# Port the backend listens on (optional, defaults to 3000)
PORT=3000
